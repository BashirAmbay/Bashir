{
  "version": 2,
  "installCommand": "npm install --no-package-lock",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://backend-o3wm.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
